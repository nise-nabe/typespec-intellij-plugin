<idea-plugin>
    <id>com.example.typespec</id>
    <name>TypeSpec Language</name>
    <vendor>nise_nabe</vendor>

    <description><![CDATA[
        A plugin that makes working with TypeSpec `.tsp` files easier in IntelliJ Platform IDEs.<br>
        It integrates with the TypeSpec Language Server to provide the essential editing experience for TypeSpec development.<br>
        <br>
        Key features:<br>
        <ul>
            <li>Recognition of `.tsp` files</li>
            <li>Code completion, diagnostics, and navigation support powered by the TypeSpec Language Server</li>
            <li>LSP-based editing support for TypeSpec projects</li>
            <li>Project settings to configure the TypeSpec Language Server package path and enable or disable the service</li>
            <li>Inspections and quick fixes for TypeSpec extension package <code>package.json</code> metadata</li>
            <li>VS Code parity commands: restart server, show output, emit, create project, OpenAPI import, API documentation preview</li>
        </ul>
    ]]></description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lsp</depends>
    <depends>JavaScript</depends>
    <depends>NodeJS</depends>
    <depends>com.intellij.modules.spellchecker</depends>
    <depends>com.intellij.modules.json</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="TypeSpec Notifications" displayType="BALLOON"/>

        <fileType name="TypeSpec"
                  implementationClass="com.example.typespec.TypeSpecFileType"
                  fieldName="INSTANCE"
                  language="TypeSpec"
                  extensions="tsp"/>

        <platform.lsp.integrationProvider implementation="com.example.typespec.TypeSpecLspServerSupportProvider"/>
        <spellchecker.bundledDictionaryProvider implementation="com.example.typespec.TypeSpecBundledDictionaryProvider"/>
        <postStartupActivity implementation="com.example.typespec.TypeSpecLspPackageResolutionCacheWatcherInitializer"/>

        <projectConfigurable parentId="language"
                             instance="com.example.typespec.TypeSpecSettingsConfigurable"
                             id="settings.typespec"
                             key="settings.typespec.title"
                             bundle="messages.TypeSpecBundle"
                             nonDefaultProject="true"/>

        <localInspection language="JSON"
                         shortName="TypeSpecPackageJsonInspection"
                         bundle="messages.TypeSpecBundle"
                         key="inspection.typeSpecPackageJson.displayName"
                         groupPath="JavaScript and TypeScript,TypeSpec"
                         groupKey="inspection.group.typeSpecPackageJson"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.example.typespec.inspections.TypeSpecPackageJsonInspection"/>

        <toolWindow id="TypeSpec Output"
                    anchor="bottom"
                    factoryClass="com.example.typespec.workflow.TypeSpecToolWindowFactory"
                    icon="AllIcons.FileTypes.Any_type"
                    bundle="messages.TypeSpecBundle"
                    key="toolWindow.typespecOutput.title"/>

        <projectService serviceImplementation="com.example.typespec.workflow.TypeSpecOutputService"/>

        <projectService serviceInterface="com.example.typespec.TypeSpecLanguageServerCommandExecutor"
                          serviceImplementation="com.example.typespec.TypeSpecLanguageServerCommandExecutorImpl"/>

        <projectListeners>
            <listener class="com.example.typespec.TypeSpecLspServiceSettingsListener"
                      topic="com.example.typespec.TypeSpecServiceSettingsListener"/>
        </projectListeners>

        <configurationType implementation="com.example.typespec.run.TypeSpecCompileRunConfigurationType"/>
        <runConfigurationProducer implementation="com.example.typespec.run.TypeSpecCompileRunConfigurationProducer"/>
    </extensions>

    <actions resource-bundle="messages.TypeSpecBundle">
        <group id="TypeSpec.Tools" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="TypeSpec.RestartServer" class="com.example.typespec.actions.TypeSpecRestartServerAction"/>
            <action id="TypeSpec.ShowOutput" class="com.example.typespec.actions.TypeSpecShowOutputAction"/>
            <action id="TypeSpec.EmitFromTypeSpec" class="com.example.typespec.actions.TypeSpecEmitFromTypeSpecAction"/>
            <action id="TypeSpec.CreateProject" class="com.example.typespec.actions.TypeSpecCreateProjectAction"/>
            <action id="TypeSpec.ImportFromOpenApi" class="com.example.typespec.actions.TypeSpecImportFromOpenApiAction"/>
            <separator/>
            <action id="TypeSpec.PreviewOpenApi" class="com.example.typespec.actions.TypeSpecPreviewOpenApiAction"/>
        </group>

        <group id="TypeSpec.EditorPopup">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <separator/>
            <reference ref="TypeSpec.EmitFromTypeSpec"/>
            <reference ref="TypeSpec.PreviewOpenApi"/>
            <reference ref="TypeSpec.RestartServer"/>
            <reference ref="TypeSpec.ShowOutput"/>
        </group>

        <group id="TypeSpec.ProjectViewPopup">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <separator/>
            <reference ref="TypeSpec.EmitFromTypeSpec"/>
            <reference ref="TypeSpec.ImportFromOpenApi"/>
            <reference ref="TypeSpec.CreateProject"/>
        </group>
    </actions>
</idea-plugin>
