<idea-plugin>
    <id>com.example.typespec</id>
    <name>TypeSpec Language</name>
    <vendor>nise_nabe</vendor>

    <description><![CDATA[
        A plugin that makes working with TypeSpec `.tsp` files easier in IntelliJ Platform IDEs.<br>
        It integrates with the TypeSpec Language Server to provide the essential editing experience for TypeSpec development.<br>
        <br>
        Key features:<br>
        <ul>
            <li>Recognition of `.tsp` files</li>
            <li>Code completion, diagnostics, and navigation support powered by the TypeSpec Language Server</li>
            <li>LSP-based editing support for TypeSpec projects</li>
            <li>Project settings to configure the TypeSpec Language Server package path and enable or disable the service</li>
            <li>Inspections and quick fixes for TypeSpec extension package <code>package.json</code> metadata</li>
        </ul>
    ]]></description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lsp</depends>
    <depends>JavaScript</depends>
    <depends>NodeJS</depends>
    <depends>com.intellij.modules.spellchecker</depends>
    <depends>com.intellij.modules.json</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="TypeSpec Notifications" displayType="BALLOON"/>

        <fileType name="TypeSpec"
                  implementationClass="com.example.typespec.TypeSpecFileType"
                  fieldName="INSTANCE"
                  language="TypeSpec"
                  extensions="tsp"/>

        <platform.lsp.serverSupportProvider implementation="com.example.typespec.TypeSpecLspServerSupportProvider"/>
        <spellchecker.bundledDictionaryProvider implementation="com.example.typespec.TypeSpecBundledDictionaryProvider"/>
        <projectSettings service="com.example.typespec.TypeSpecServiceSettings" />
        <postStartupActivity implementation="com.example.typespec.TypeSpecLspPackageResolutionCacheWatcherInitializer"/>

        <projectConfigurable parentId="language"
                             instance="com.example.typespec.TypeSpecSettingsConfigurable"
                             id="settings.typespec"
                             key="settings.typespec.title"
                             bundle="messages.TypeSpecBundle"
                             nonDefaultProject="true"/>

        <localInspection language="JSON"
                         shortName="TypeSpecPackageJsonInspection"
                         bundle="messages.TypeSpecBundle"
                         key="inspection.typeSpecPackageJson.displayName"
                         groupPath="JavaScript and TypeScript,TypeSpec"
                         groupKey="inspection.group.typeSpecPackageJson"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.example.typespec.inspections.TypeSpecPackageJsonInspection"/>
    </extensions>
</idea-plugin>
